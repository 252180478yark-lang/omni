# ═══ Omni-Vibe OS Ultra — 环境变量 ═══
# 复制为 .env 并填写实际值：cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=omni_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=omni_vibe_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379

# --- Nginx ---
NGINX_PORT=80
NGINX_SSL_PORT=443

# --- Embedding Model ---
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2-preview

# --- 代理设置（国内访问 OpenAI/Gemini 等）---
# Docker Compose 会把它注入各服务：优先 HTTP_PROXY/HTTPS_PROXY，否则用 PROXY_URL。
# 容器内不要用 127.0.0.1，应指向宿主机，例如 Clash「混合端口」12334：
#   PROXY_URL=http://host.docker.internal:12334
# Clash「允许来自局域网的连接」建议开启，否则 Docker 网桥访问宿主机代理可能被拒绝。
PROXY_URL=
HTTP_PROXY=
HTTPS_PROXY=
