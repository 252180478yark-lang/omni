SERVICE_NAME=ai-provider-hub
SERVICE_PORT=8001
LOG_LEVEL=INFO

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Video generation — Seedance 2.0 (火山方舟 Ark)
# 推荐使用 ARK_API_KEY（从 https://console.volcengine.com/ark/region:ark+cn-beijing/apikey 获取）
ARK_API_KEY=
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_FAST_MODEL=doubao-seedance-2-0-fast-260128
# Legacy keys (若 ARK_API_KEY 为空则回退到这组)
SEEDANCE_ACCESS_KEY=
SEEDANCE_SECRET_KEY=
# Kling (可灵) video generation
KLING_API_KEY=

DEFAULT_CHAT_PROVIDER=gemini
DEFAULT_EMBEDDING_PROVIDER=gemini
REQUEST_TIMEOUT_SECONDS=120
# 流式长回答（如 RAG）读取超时（秒），过短会中途断流
CHAT_STREAM_TIMEOUT_SECONDS=900
PROVIDER_CONFIG_PATH=/app/data/provider-config.json

REDIS_URL=redis://:changeme_redis@omni-redis:6379/0