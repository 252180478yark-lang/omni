APP_ENV=dev
SERVICE_NAME=news-aggregator
SERVICE_PORT=8005
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://omni:password@postgres:5432/omni
REDIS_URL=redis://redis:6379/2

SERPER_API_KEY=your_serper_key_here
BOCHA_API_KEY=your_bocha_key_here
TIANAPI_KEY=your_tianapi_key_here

SP3_BASE_URL=http://ai-provider-hub:8001
SP4_BASE_URL=http://knowledge-engine:8002

SP5_DEFAULT_FRESHNESS=oneDay
SP5_RELEVANCE_THRESHOLD=0.3
SP5_ENRICH_BATCH_SIZE=5
SP5_TARGET_KB_ID=default

ENRICHER_PROVIDER=gemini
ENRICHER_MODEL=gemini-2.0-flash
ENRICHER_MAX_TOKENS=2000
