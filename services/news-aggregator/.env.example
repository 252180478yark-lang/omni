APP_ENV=dev
SERVICE_NAME=news-aggregator
SERVICE_PORT=8005
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://omni_user:changeme_in_production@omni-postgres:5432/omni_vibe_db
REDIS_URL=redis://:changeme_redis@omni-redis:6379/2

SERPER_API_KEY=your_serper_api_key_here
BOCHA_API_KEY=your_bocha_api_key_here
TIANAPI_KEY=your_tianapi_key_here

# RSS 免费源（无需 API Key），逗号分隔
# 中文示例: 36kr, 虎嗅, BBC中文, 少数派
# RSS_FEED_URLS=https://rss.36kr.com/feeds,https://www.huxiu.com/rss/0.xml,https://feeds.bbci.co.uk/zhongwen/simp/rss.xml,https://sspai.com/feed
RSS_FEED_URLS=

SP3_BASE_URL=http://ai-provider-hub:8001
SP4_BASE_URL=http://knowledge-engine:8002

SP5_DEFAULT_FRESHNESS=oneDay
SP5_RELEVANCE_THRESHOLD=0.3
SP5_ENRICH_BATCH_SIZE=5
SP5_TARGET_KB_ID=default

ENRICHER_PROVIDER=gemini
ENRICHER_MODEL=gemini-2.0-flash
ENRICHER_MAX_TOKENS=2000
