SERVICE_NAME=knowledge-engine
SERVICE_PORT=8002

AI_PROVIDER_HUB_URL=http://ai-provider-hub:8001
VIDEO_ANALYSIS_SERVICE_URL=http://video-analysis:8006
DATABASE_URL=postgresql+asyncpg://omni_user:changeme_in_production@omni-postgres:5432/omni_vibe_db
REDIS_URL=redis://:changeme_redis@omni-redis:6379/1

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2-preview
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_BATCH_SIZE=100

# RAG：单次回答里「引用来源」每条正文的截断长度（字符）
RAG_SOURCE_SNIPPET_MAX_CHARS=2000
# RAG 生成时传给对话模型的 max_tokens（受模型/API 实际上限限制）
RAG_MAX_OUTPUT_TOKENS=131072
# 多轮续写（target_chars>0）：最大轮次、达标比例、单请求目标字数上限
RAG_CONTINUE_MAX_ROUNDS=20
RAG_CONTINUE_TARGET_RATIO=0.95
RAG_CONTINUE_MAX_TARGET_CHARS=200000

DATABASE_PATH=/app/data/knowledge.db
